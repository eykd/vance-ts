{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"4e5c5751d05f529b0076990e34cbc54ab19d0b357cbafe75874006cd573df5e0","created_at":"2026-03-20T22:57:07Z","created_by":"eykd","crystallizes":0,"defer_until":null,"description":"Visiting /auth/sign-in?registered=true shows 'Account created successfully. Please sign in.' success banner without any actual registration. While low-risk (no data exposure), it's a UX inconsistency. The success state should be tied to a server-side session flag rather than a client-visible query parameter.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"clawtask-1y8.1.16","is_template":0,"issue_type":"task","last_activity":null,"metadata":"{}","mol_type":"","no_history":0,"notes":"","original_size":null,"owner":"david@worldsenoughstudios.com","payload":"","pinned":0,"priority":2,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"Sign-in: 'registered=true' query parameter is spoofable","updated_at":"2026-03-20T22:57:07Z","waiters":"","wisp_type":"","work_type":""}
