{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"272eef44cf7c7b2bc8a8bbe0b640091b27add4be7d60c38d87a6d6a2a07e40ab","created_at":"2026-03-20T22:47:38Z","created_by":"eykd","crystallizes":0,"defer_until":null,"description":"The RSS feed at /index.xml has title 'Welcome to My Hugo Site on ClawTask' and description 'A modern static website built with Hugo, TailwindCSS, and DaisyUI'. Both should reflect actual ClawTask branding and description.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"clawtask-1y8.1.3","is_template":0,"issue_type":"task","last_activity":null,"metadata":"{}","mol_type":"","no_history":0,"notes":"","original_size":null,"owner":"david@worldsenoughstudios.com","payload":"","pinned":0,"priority":2,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"RSS feed: title and description contain placeholder text","updated_at":"2026-03-20T22:47:38Z","waiters":"","wisp_type":"","work_type":""}
{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"6a965074f7461608a6f8e5c64417c7701b3687ccc3ba06b0700b5e7161bc9581","created_at":"2026-03-20T22:47:44Z","created_by":"eykd","crystallizes":0,"defer_until":null,"description":"Static Hugo pages (homepage, about, posts, etc.) set data-theme='lemonade' while dynamic auth pages (sign-in, sign-up, rate-limit) set data-theme='turtlebased'. This creates a jarring visual inconsistency when navigating between static and dynamic pages. Both should use the same theme.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"clawtask-1y8.1.4","is_template":0,"issue_type":"task","last_activity":null,"metadata":"{}","mol_type":"","no_history":0,"notes":"","original_size":null,"owner":"david@worldsenoughstudios.com","payload":"","pinned":0,"priority":2,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"Theme mismatch: Hugo pages use 'lemonade' but auth pages use 'turtlebased'","updated_at":"2026-03-20T22:47:44Z","waiters":"","wisp_type":"","work_type":""}
{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"4b3c8d990aeabf81ca740f7dac25db5b986758e2e3e7c3e030993b39d6256afa","created_at":"2026-03-20T22:47:51Z","created_by":"eykd","crystallizes":0,"defer_until":null,"description":"The sign-in, sign-up, and rate-limit pages have no navbar, logo link, or any way to navigate back to the main site. Users who land on these pages can only use browser back. All other pages have the full navbar. Auth pages should include at minimum a ClawTask logo linking to home.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"clawtask-1y8.1.5","is_template":0,"issue_type":"task","last_activity":null,"metadata":"{}","mol_type":"","no_history":0,"notes":"","original_size":null,"owner":"david@worldsenoughstudios.com","payload":"","pinned":0,"priority":2,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"Auth pages: no site navigation or branding — users get trapped","updated_at":"2026-03-20T22:47:51Z","waiters":"","wisp_type":"","work_type":""}
{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"c9c11b165f8016f80e7d3729ec2a92defb8b42274189e5e6a9a70886f69aa3f3","created_at":"2026-03-20T22:47:54Z","created_by":"eykd","crystallizes":0,"defer_until":null,"description":"The sign-up form has no indication of password requirements (minimum length, complexity, etc.). When a weak password is rejected, the user has no prior guidance on what constitutes an acceptable password. Should display password requirements near the password field.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"clawtask-1y8.1.6","is_template":0,"issue_type":"task","last_activity":null,"metadata":"{}","mol_type":"","no_history":0,"notes":"","original_size":null,"owner":"david@worldsenoughstudios.com","payload":"","pinned":0,"priority":2,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"Sign-up form: no password requirements shown to user","updated_at":"2026-03-20T22:47:54Z","waiters":"","wisp_type":"","work_type":""}
{"acceptance_criteria":"","actor":"","agent_state":"","assignee":null,"await_id":"","await_type":"","close_reason":"","closed_at":null,"closed_by_session":"","compacted_at":null,"compacted_at_commit":null,"compaction_level":0,"content_hash":"4ad5308aa638d1d12967ae803a2172ea94cd1c728ce33002ca2e33a9f5da6d9b","created_at":"2026-03-20T22:47:56Z","created_by":"eykd","crystallizes":0,"defer_until":null,"description":"The 404 page at /404.html has \u003cmeta name=robots content='index, follow'\u003e. Search engines should not index 404 pages. Should be 'noindex, follow' or 'noindex, nofollow'. Also, og:type is 'article' when it should be 'website'.","design":"","due_at":null,"ephemeral":0,"estimated_minutes":null,"event_kind":"","external_ref":null,"hook_bead":"","id":"clawtask-1y8.1.7","is_template":0,"issue_type":"task","last_activity":null,"metadata":"{}","mol_type":"","no_history":0,"notes":"","original_size":null,"owner":"david@worldsenoughstudios.com","payload":"","pinned":0,"priority":2,"quality_score":null,"rig":"","role_bead":"","role_type":"","sender":"","source_repo":"","source_system":"","spec_id":"","status":"open","target":"","timeout_ns":0,"title":"404 page: robots meta allows indexing (should be noindex)","updated_at":"2026-03-20T22:47:56Z","waiters":"","wisp_type":"","work_type":""}
