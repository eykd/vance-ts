{
  "name": "turtlebased-ts",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist coverage",
    "lint": "eslint src .claude/memory .claude/types tools --ext .ts --no-error-on-unmatched-pattern",
    "lint:fix": "eslint src .claude/memory .claude/types tools --ext .ts --fix --no-error-on-unmatched-pattern",
    "format": "prettier --write --no-error-on-unmatched-pattern \"src/**/*.ts\" \".claude/memory/**/*.ts\" \".claude/types/**/*.ts\" \"tools/**/*.ts\"",
    "format:check": "prettier --check --no-error-on-unmatched-pattern \"src/**/*.ts\" \".claude/memory/**/*.ts\" \".claude/types/**/*.ts\" \"tools/**/*.ts\"",
    "test": "vitest run --project=workers && vitest run --project=node && vitest run --project=acceptance",
    "test:ci": "vitest run --retry=2 --reporter=default --reporter=json --outputFile=test-results.json",
    "test:workers": "vitest run --project=workers",
    "test:acceptance": "vitest run --project=acceptance",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --project=node",
    "test:leak-detect": "DETECT_STATE_LEAKS=true vitest run --project=acceptance",
    "type-check": "tsc --noEmit",
    "check": "npm run type-check && npm run lint && npm run test",
    "validate": "npm run type-check && npm run lint && npm run format:check && npm run test:coverage && npm run build",
    "fix": "npm run format && npm run lint:fix",
    "dev:worker": "wrangler dev",
    "actionlint": "npx -y @tktco/node-actionlint",
    "test:mutants": "stryker run",
    "lint:unused": "knip",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/turtlebased/turtlebased-ts.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/turtlebased/turtlebased-ts/issues"
  },
  "homepage": "https://github.com/turtlebased/turtlebased-ts#readme",
  "lint-staged": {
    "hugo/{assets/css/styles.css,layouts/**/*.html,tailwind.config.js}": [
      "bash -c 'rm -rf hugo/public && cd hugo && npx hugo --minify && cd .. && node scripts/sync-asset-paths.js && git add src/presentation/generated/assetPaths.ts'"
    ],
    "src/**/*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "bash -c 'tsc --noEmit'",
      "vitest related --run"
    ],
    ".claude/**/*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings 0",
      "bash -c 'tsc --noEmit'",
      "vitest related --run --passWithNoTests"
    ],
    "tools/**/*.ts": [
      "prettier --write",
      "eslint --fix --max-warnings 0",
      "bash -c 'tsc --noEmit -p tools/galaxy-generator/tsconfig.json'",
      "bash -c 'tsc --noEmit -p tools/galaxy-seeder/tsconfig.json'",
      "vitest related --run --passWithNoTests"
    ],
    "hugo/**/*.html": [
      "bash -c 'cd hugo && npm test'"
    ],
    ".github/workflows/*.{yml,yaml}": [
      "prettier --write",
      "npm run actionlint"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@sentry/cli": "^2.58.5",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tktco/node-actionlint": "^1.6.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^4.1.5",
    "better-sqlite3": "^12.9.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "fast-png": "^8.0.0",
    "husky": "^9.1.7",
    "knip": "^6.7.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "simplex-noise": "^4.0.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0"
  },
  "dependencies": {
    "@noble/hashes": "^2.0.1",
    "@sentry/cloudflare": "^10.46.0",
    "better-auth": "1.5.6",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "yaml": "^2.8.3"
  },
  "overrides": {
    "@sveltejs/vite-plugin-svelte": {
      "vite": "^7.3.1"
    }
  }
}
