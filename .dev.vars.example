# Local development secrets for Wrangler
# Copy this file to .dev.vars and fill in the values:
#   cp .dev.vars.example .dev.vars
#
# NEVER commit .dev.vars — it contains secrets.

# Generate with: openssl rand -hex 32 (must be >= 32 characters)
BETTER_AUTH_SECRET=
# Public base URL for better-auth (use localhost for local dev)
BETTER_AUTH_URL=http://localhost:8787
# Sentry DSN for error tracking (set via 'wrangler secret put SENTRY_DSN' in production)
SENTRY_DSN=
